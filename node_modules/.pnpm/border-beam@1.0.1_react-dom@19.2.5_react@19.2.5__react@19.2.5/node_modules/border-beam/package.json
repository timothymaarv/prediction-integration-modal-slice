{
  "name": "border-beam",
  "version": "1.0.1",
  "description": "Animated border beam effect for React",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.es.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0"
  },
  "keywords": [
    "react",
    "animation",
    "border",
    "beam",
    "glow",
    "effect",
    "css"
  ],
  "author": "Jakub Antalik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jakubantalik/border-beam.git"
  },
  "bugs": {
    "url": "https://github.com/Jakubantalik/border-beam/issues"
  },
  "homepage": "https://github.com/Jakubantalik/border-beam#readme"
}
