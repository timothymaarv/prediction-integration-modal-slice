{
  "name": "dialkit",
  "version": "1.2.0",
  "description": "Real-time parameter tweaking for React, Solid, and Svelte apps",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./solid": {
      "import": {
        "types": "./dist/solid/index.d.ts",
        "default": "./dist/solid/index.js"
      },
      "require": {
        "types": "./dist/solid/index.d.cts",
        "default": "./dist/solid/index.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue/index.d.ts",
        "default": "./dist/vue/index.js"
      },
      "require": {
        "types": "./dist/vue/index.d.cts",
        "default": "./dist/vue/index.cjs"
      }
    },
    "./store": {
      "import": {
        "types": "./dist/store/index.d.ts",
        "default": "./dist/store/index.js"
      },
      "require": {
        "types": "./dist/store/index.d.cts",
        "default": "./dist/store/index.cjs"
      }
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup && npm run build:svelte",
    "build:svelte": "node scripts/gen-theme-css.js && svelte-package -i src/svelte -o dist/svelte && rm -rf .svelte-kit src/store/DialStore.d.ts src/store/DialStore.d.ts.map",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.solid.json && tsc --noEmit -p tsconfig.vue.json && node scripts/gen-theme-css.js && svelte-check --tsconfig tsconfig.svelte.json"
  },
  "peerDependencies": {
    "motion": ">=11.0.0",
    "motion-v": ">=2.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "solid-js": ">=1.6.0",
    "svelte": ">=5.8.0",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "motion-v": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/package": "^2.4.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "esbuild-plugin-solid": "^0.6.0",
    "motion": "^12.0.0",
    "motion-v": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "solid-js": "^1.9.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vue": "^3.5.0"
  },
  "keywords": [
    "react",
    "solid",
    "solidjs",
    "svelte",
    "animation",
    "tweaking",
    "parameters",
    "devtools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshpuckett/dialkit"
  }
}
